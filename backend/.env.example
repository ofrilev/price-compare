# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# JWT Secret (generate a strong random string for production)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-secret-in-production

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Used when >3 sites or category compare (default: gpt-4o)
OPENAI_MODEL_BETTER=gpt-4o

# LLM + web search mode: model with built-in web search
# gpt-4o-mini-search-preview is more widely available; gpt-4o-search-preview may require tier
# Note: search models do NOT support temperature, top_p, frequency_penalty
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini-search-preview
